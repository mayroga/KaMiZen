{
"sys":"KAMIZEN LIFE SYSTEM",
"ch":3,
"rng":"15-21",

"ui":{"fw":["AWARENESS","CALM","CONTROL","FOCUS","TRUTH","SAFETY","ACTION","HELP"]},

"rules":[
"Awareness>Reaction",
"Calm>Impulse",
"AskHelp=Strength",
"Distance>Conflict",
"Truth=Protection",
"Action=Safety"
],

"missions":[

{
"id":15,
"cat":"emotion",
"b":[
{"t":"v","tx":{"en":"Today: EMOTIONAL CONTROL"}},
{"t":"h","tx":{"en":"Your emotions are real, but not always true"}},

{"story":{"en":"The first emotion is automatic. The second action is your responsibility."}},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
},

{"t":"d","q":{"en":"What gives you real control?"},
"op":["React instantly","Pause and breathe","Attack back","Enter conflict"],
"c":1,
"ex":[
"Instant reaction = emotional control loss",
"Pause + breathe = control regained",
"Attack = escalation",
"Entering conflict = unnecessary risk"
]},

{"t":"r","tx":"+Control","p":20},

{"t":"sil","d":30,
"tx":{"en":"Observe your emotion without reacting"},
"inf":{"en":"Reduces impulsive reactions and strengthens self-control"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
}
]
},

{
"id":16,
"cat":"focus",
"b":[
{"t":"v","tx":{"en":"Today: FOCUS UNDER DISTRACTION"}},
{"t":"h","tx":{"en":"Attention is your most valuable resource"}},

{"story":{"en":"Where your attention goes, your life follows. Distraction steals progress."}},

{"t":"d","q":{"en":"What creates real progress?"},
"op":["Multitask","Focus on one task","Stop working","Check phone"],
"c":1,
"ex":[
"Multitasking = shallow work",
"Single focus = deep progress",
"Stopping = no output",
"Phone = attention loss"
]},

{"t":"r","tx":"+Focus","p":20},

{"t":"sil","d":45,
"tx":{"en":"Hold your attention on one point"},
"inf":{"en":"Improves sustained focus and reduces distraction impulses"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
}
]
},

{
"id":17,
"cat":"safety",
"b":[
{"t":"v","tx":{"en":"Today: INTUITION AND SAFETY"}},
