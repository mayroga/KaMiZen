{
"sys":"KAMIZEN KIDS",
"ch":3,
"rng":"15-21",

"ui":{"fw":["DISCIPLINE","FOCUS","CALM","TRUTH","CONTROL","BREATH","AWARENESS"]},

"rules":["Obs>React","Act=Real","Thought>Emotion","Silence=Power","Focus>Noise","Breath=Ctrl"],

"ses":[

{"id":15,"cat":"emotion","b":[
{"t":"v","tx":{"en":"Today: EMOTIONAL CONTROL","es":"Hoy: CONTROL EMOCIONAL"}},
{"t":"h","tx":{"en":"Someone insults you","es":"Alguien te insulta"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":4},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":4},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Insult back","Calm","Run","Scream"],
"c":1,
"ex":[
"Amygdala hijack, loss of control",
"Prefrontal cortex activation = real power",
"Avoids emotional training",
"Increases chaos response"
]},

{"t":"r","tx":"+Control","p":20}
]},


{"id":16,"cat":"focus","b":[
{"t":"v","tx":{"en":"Today: FOCUS TEST","es":"Hoy: TEST DE ENFOQUE"}},
{"t":"h","tx":{"en":"Many distractions appear","es":"Aparecen muchas distracciones"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Switch task","Single task","Stop","Delay"],
"c":1,
"ex":[
"Breaks cognitive flow",
"Deep focus state (optimal performance)",
"No progress state",
"Increases mental stress"
]},

{"t":"r","tx":"+Focus","p":20},

{"t":"v","tx":{"en":"1 MIN SILENCE RESET","es":"RESET DE 1 MIN SILENCIO"}},

{"t":"sil","d":60,
"tx":{"en":"Observe without reaction","es":"Observa sin reaccionar"},
"inf":{
"en":"Reduces amygdala reactivity + increases attention control",
"es":"Reduce reactividad de la amígdala + mejora atención"
}
}
]},


{"id":17,"cat":"fear","b":[
{"t":"v","tx":{"en":"Today: FEAR CONTROL","es":"Hoy: CONTROL DEL MIEDO"}},
{"t":"h","tx":{"en":"You feel fear before acting","es":"Sientes miedo antes de actuar"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":5},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":5},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Stop","Act","Escape","Freeze"],
"c":1,
"ex":[
"Strengthens fear circuit",
"Creates courage through exposure",
"Reinforces avoidance behavior",
"Blocks action system"
]},

{"t":"r","tx":"+Courage","p":20}
]},


{"id":18,"cat":"truth","b":[
{"t":"v","tx":{"en":"Today: TRUTH POWER","es":"Hoy: PODER DE LA VERDAD"}},
{"t":"h","tx":{"en":"You must be honest","es":"Debes ser honesto"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Lie","Truth","Hide","Delay"],
