{"id":15,"level":15,"theme":"CONTROL EMOTION","blocks":[
{"type":"story","text":{"en":"Someone insults you directly.","es":"Alguien te insulta directamente."}},
{"type":"analysis","text":{"en":"Control defines strength.","es":"El control define fuerza."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Insult back","es":"Insultar de vuelta"},"correct":false,"explanation":"Reacting emotionally gives control to others and weakens your position."},
{"code":"B","text":{"en":"Stay calm","es":"Mantener calma"},"correct":true,"explanation":"Staying calm keeps control in your hands and shows true strength."},
{"code":"C","text":{"en":"Ignore run","es":"Ignorar y huir"},"correct":false,"explanation":"Avoiding removes growth. You lose the chance to build internal control."},
{"code":"D","text":{"en":"Shout","es":"Gritar"},"correct":false,"explanation":"Shouting escalates conflict and destroys clarity."}
]}]},

{"id":16,"level":16,"theme":"FOCUS TEST","blocks":[
{"type":"story","text":{"en":"Many distractions appear.","es":"Aparecen distracciones."}},
{"type":"analysis","text":{"en":"Focus is skill.","es":"El enfoque es habilidad."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Switch tasks","es":"Cambiar tareas"},"correct":false,"explanation":"Switching tasks breaks concentration and reduces performance."},
{"code":"B","text":{"en":"Focus one task","es":"Una sola tarea"},"correct":true,"explanation":"Single focus increases efficiency and builds discipline."},
{"code":"C","text":{"en":"Stop all","es":"Detener todo"},"correct":false,"explanation":"Stopping removes progress instead of controlling attention."},
{"code":"D","text":{"en":"Delay work","es":"Retrasar trabajo"},"correct":false,"explanation":"Delaying creates stress and weakens responsibility."}
]}]},

{"id":17,"level":17,"theme":"FEAR CONTROL","blocks":[
{"type":"story","text":{"en":"You feel fear before action.","es":"Sientes miedo antes de actuar."}},
{"type":"analysis","text":{"en":"Fear is signal.","es":"El miedo es señal."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Stop forever","es":"Detenerse"},"correct":false,"explanation":"Stopping because of fear blocks growth and opportunity."},
{"code":"B","text":{"en":"Act anyway","es":"Actuar igual"},"correct":true,"explanation":"Acting despite fear builds courage and internal strength."},
{"code":"C","text":{"en":"Escape","es":"Escapar"},"correct":false,"explanation":"Escaping reinforces fear and reduces confidence."},
{"code":"D","text":{"en":"Freeze","es":"Paralizarse"},"correct":false,"explanation":"Freezing removes control and prevents progress."}
]}]},

{"id":18,"level":18,"theme":"TRUTH POWER","blocks":[
{"type":"story","text":{"en":"You must choose honesty.","es":"Debes elegir honestidad."}},
{"type":"analysis","text":{"en":"Truth builds power.","es":"La verdad construye poder."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Lie","es":"Mentir"},"correct":false,"explanation":"Lying creates short-term relief but destroys long-term trust."},
{"code":"B","text":{"en":"Tell truth","es":"Decir verdad"},"correct":true,"explanation":"Truth builds trust, clarity, and strong identity."},
{"code":"C","text":{"en":"Hide","es":"Ocultar"},"correct":false,"explanation":"Hiding delays consequences and increases pressure."},
{"code":"D","text":{"en":"Delay","es":"Retrasar"},"correct":false,"explanation":"Delaying truth makes problems grow over time."}
]}]},

{"id":19,"level":19,"theme":"SOCIAL PRESSURE","blocks":[
{"type":"story","text":{"en":"Group pushes wrong action.","es":"El grupo presiona mal."}},
{"type":"analysis","text":{"en":"Independence matters.","es":"La independencia importa."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Follow group","es":"Seguir grupo"},"correct":false,"explanation":"Following others removes your identity and control."},
{"code":"B","text":{"en":"Stand firm","es":"Mantener firme"},"correct":true,"explanation":"Standing firm protects your values and builds strength."},
{"code":"C","text":{"en":"Laugh it off","es":"Reírse"},"correct":false,"explanation":"Avoiding the situation prevents real decision-making."},
{"code":"D","text":{"en":"Leave panic","es":"Salir en pánico"},"correct":false,"explanation":"Panic decisions reduce clarity and control."}
]}]},

{"id":20,"level":20,"theme":"DISCIPLINE","blocks":[
{"type":"story","text":{"en":"You want to quit early.","es":"Quieres rendirte."}},
{"type":"analysis","text":{"en":"Discipline wins.","es":"La disciplina gana."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Quit","es":"Rendirse"},"correct":false,"explanation":"Quitting builds weak habits and stops progress."},
{"code":"B","text":{"en":"Continue","es":"Continuar"},"correct":true,"explanation":"Continuing builds discipline and long-term success."},
{"code":"C","text":{"en":"Delay","es":"Retrasar"},"correct":false,"explanation":"Delaying reduces consistency and weakens results."},
{"code":"D","text":{"en":"Avoid","es":"Evitar"},"correct":false,"explanation":"Avoiding removes responsibility and growth."}
]}]},

{"id":21,"level":21,"theme":"SELF MASTER","blocks":[
{"type":"story","text":{"en":"You must control yourself.","es":"Debes controlarte."}},
{"type":"analysis","text":{"en":"Mastery is internal.","es":"La maestría es interna."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"React","es":"Reaccionar"},"correct":false,"explanation":"Reacting automatically means lack of control."},
{"code":"B","text":{"en":"Control self","es":"Autocontrol"},"correct":true,"explanation":"Self-control is the foundation of mastery and power."},
{"code":"C","text":{"en":"Escape","es":"Escapar"},"correct":false,"explanation":"Escaping avoids the challenge instead of mastering it."},
{"code":"D","text":{"en":"Ignore","es":"Ignorar"},"correct":false,"explanation":"Ignoring prevents awareness and improvement."}
