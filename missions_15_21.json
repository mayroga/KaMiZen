"ex":[
"Cognitive stress + internal conflict",
"Aligns identity and behavior",
"Increases pressure internally",
"Problem escalates"
]},

{"t":"r","tx":"+Integrity","p":20}
]},


{"id":19,"cat":"social","b":[
{"t":"v","tx":{"en":"Today: SOCIAL PRESSURE","es":"Hoy: PRESIÓN SOCIAL"}},
{"t":"h","tx":{"en":"Group pushes wrong decision","es":"El grupo empuja una mala decisión"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Follow","Stand firm","Laugh","Panic"],
"c":1,
"ex":[
"Identity loss mechanism",
"Self-respect activation",
"Avoids decision responsibility",
"Reduces cognitive control"
]},

{"t":"r","tx":"+Character","p":20}
]},


{"id":20,"cat":"discipline","b":[
{"t":"v","tx":{"en":"Today: DISCIPLINE","es":"Hoy: DISCIPLINA"}},
{"t":"h","tx":{"en":"You feel like quitting","es":"Sientes ganas de rendirte"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":3},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":3},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Quit","Continue","Delay","Avoid"],
"c":1,
"ex":[
"Weak habit reinforcement",
"Neuroplasticity strengthening loop",
"Consistency break",
"No growth cycle"
]},

{"t":"r","tx":"+Discipline","p":20},

{"t":"v","tx":{"en":"2 MIN SILENCE TRAINING","es":"ENTRENAMIENTO 2 MIN SILENCIO"}},

{"t":"sil","d":120,
"tx":{"en":"Observe thoughts without reaction","es":"Observa pensamientos sin reaccionar"},
"inf":{
"en":"Strengthens executive control and impulse inhibition",
"es":"Fortalece control ejecutivo e inhibición de impulsos"
}
}
]},


{"id":21,"cat":"mastery","b":[
{"t":"v","tx":{"en":"Today: SELF MASTERY","es":"Hoy: MAESTRÍA PERSONAL"}},
