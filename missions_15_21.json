{"story":{"en":"Your brain detects danger before you understand it. Ignoring it increases risk."}},

{"t":"d","q":{"en":"What is the smartest move?"},
"op":["Ignore feeling","Move away and get help","Stay anyway","Act fast without thinking"],
"c":1,
"ex":[
"Ignoring = missed warning",
"Moving away + help = protection",
"Staying = exposure",
"Impulsive action = poor decision"
]},

{"t":"r","tx":"+Safety","p":20},

{"t":"sil","d":60,
"tx":{"en":"Notice your internal signals"},
"inf":{"en":"Improves awareness of early risk detection"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
}
]
},

