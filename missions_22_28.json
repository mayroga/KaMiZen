},

{"t":"d","q":{"en":"What creates emotional mastery?"},
"op":["React instantly","Pause and regulate","Suppress everything","Escalate emotion"],
"c":1,
"ex":[
"Instant reaction = loss of control",
"Pause + regulation = mastery",
"Suppression = internal tension",
"Escalation = emotional overload"
]},

{"t":"d","q":{"en":"When anger appears, what is first useful step?"},
"op":["Act immediately","Name the emotion silently","Shout","Ignore completely"],
"c":1,
"ex":[
"Immediate action = impulsive error",
"Naming emotion = cognitive control",
"Shouting = escalation",
"Ignoring = unresolved stress"
]},

{"t":"r","tx":"+Control","p":25},

{"t":"sil","d":50,
"tx":{"en":"Watch emotion like an observer, not a participant"},
