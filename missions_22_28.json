{
"id":22,
"cat":"situational_awareness",
"b":[

{"t":"v","tx":{"en":"MISSION 22: SITUATIONAL AWARENESS"}},
{"t":"h","tx":{"en":"Danger is usually preceded by patterns"}},

{"story":{"en":"Most problems are not surprises. They are ignored signals that grow over time."}},

{"t":"breath_auto","d":25,
"tx":{"en":"Breathe slowly and scan your environment mentally"},
"inf":{"en":"This activates sustained attention networks and reduces automatic behavior"}
},

{"t":"d","q":{"en":"What increases your real safety in public places?"},
"op":["Ignoring surroundings","Observing people and exits","Looking only at phone","Walking distracted"],
"c":1,
"ex":[
"Ignoring = missed signals",
"Observation = early detection",
"Phone focus = reduced awareness",
"Distraction = delayed reaction"
]},

{"t":"d","q":{"en":"What is a hidden risk signal?"},
"op":["Calm environment awareness","Unusual discomfort feeling","Perfect silence always","Familiar routine only"],
"c":1,
"ex":[
"Calm awareness = normal state",
"Discomfort signal = intuition warning",
"Silence is not always risk",
"Routine alone does not detect change"
]},

{"t":"r","tx":"+Awareness","p":25},

{"t":"sil","d":40,
"tx":{"en":"Observe without reacting or judging"},
"inf":{"en":"Builds environmental mapping and threat detection accuracy"}
},

{"t":"breath_auto","d":25,
"tx":{"en":"4-4 breathing balance"},
"inf":{"en":"Regulates autonomic nervous system for clarity"}
}

]
},

{
"id":23,
"cat":"emotional_regulation",
"b":[

{"t":"v","tx":{"en":"MISSION 23: EMOTIONAL REGULATION"}},
