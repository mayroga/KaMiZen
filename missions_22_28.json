{
"id":22,
"cat":"awareness",
"b":[
{"t":"v","tx":{"en":"Today: AWARENESS"}},
{"t":"h","tx":{"en":"Reality always sends signals before problems appear"}},

{"story":{"en":"Most danger is not sudden. It is ignored until it becomes visible."}},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
},

{"t":"d","q":{"en":"What creates real safety?"},
"op":["Ignore environment","Observe surroundings","Focus only on phone","Distract yourself"],
"c":1,
"ex":[
"Ignore = missed signals",
"Observation = early detection",
"Phone focus = reduced awareness",
"Distraction = delayed reaction"
]},

{"t":"r","tx":"+Awareness","p":20},

{"t":"sil","d":30,
"tx":{"en":"Observe without reacting"},
"inf":{"en":"Improves situational perception and reduces impulsive response"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"4-4 breathing stability"},
"inf":{"en":"Regulates nervous system and improves focus"}
}
]
},

