{
"sys":"KAMIZEN KIDS",
"ch":4,
"rng":"22-28",

"ui":{"fw":["VISION","CONTROL","FOCUS","DISCIPLINE","CALM","TRUTH","AWARENESS"]},

"rules":["Obs>React","Act=Real","Thought>Emotion","Silence=Power","Focus>Noise","Breath=Ctrl"],

"ses":[

{"id":22,"cat":"aware","b":[
{"t":"v","tx":{"en":"Today: AWARENESS","es":"Hoy: CONCIENCIA"}},
{"t":"h","tx":{"en":"There is a hidden detail","es":"Hay un detalle oculto"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Ignore","Observe","Run","Guess"],
"c":1,
"ex":[
"Ignore = lose key information",
"Observe = detect patterns (mental advantage)",
"Run = avoid understanding",
"Guess = no logic, more error"
]},

{"t":"r","tx":"+Awareness","p":20},
{"t":"c","tx":{"en":"See more = know more","es":"Ver más = saber más"}}
]},

{"id":23,"cat":"emotion","b":[
{"t":"v","tx":{"en":"Today: EMOTIONAL CONTROL","es":"Hoy: CONTROL EMOCIONAL"}},
{"t":"h","tx":{"en":"Emotion rises fast","es":"La emoción sube rápido"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":5},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":5,
"inf":{"en":"Activates parasympathetic system → reduces stress hormones (cortisol)",
"es":"Activa sistema parasimpático → reduce hormonas del estrés (cortisol)"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Explode","Breathe","Scream","Escape"],
"c":1,
"ex":[
"Explode = emotion dominates",
"Breathe = regulates nervous system",
"Scream = increases chaos",
"Escape = no real control"
]},

{"t":"r","tx":"+Control","p":20},
{"t":"c","tx":{"en":"Breathing = mental reset","es":"Respirar = reset mental"}}
]},

{"id":24,"cat":"decision","b":[
{"t":"v","tx":{"en":"Today: DECISION","es":"Hoy: DECISIÓN"}},
{"t":"h","tx":{"en":"Limited time","es":"Tiempo limitado"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Rush","Think","Random","Stop"],
"c":1,
"ex":[
"Rushing = errors",
"Thinking = precision (prefrontal cortex active)",
"Random = no control",
"Stopping = no solution"
]},

{"t":"r","tx":"+Clarity","p":20},
{"t":"c","tx":{"en":"Think first = better results","es":"Pensar antes = mejores resultados"}}
]},

{"id":25,"cat":"learn","b":[
{"t":"v","tx":{"en":"Today: ERROR","es":"Hoy: ERROR"}},
{"t":"h","tx":{"en":"You make a mistake","es":"Cometes un error"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Ignore","Learn","Blame","Hide"],
"c":1,
"ex":[
"Ignore = repeat error",
"Learn = neuroplasticity activates growth",
"Blame = lose power",
"Hide = problem grows"
]},

{"t":"r","tx":"+Learning","p":20},
{"t":"c","tx":{"en":"Error = opportunity","es":"Error = oportunidad"}}
]},

{"t":"br",
"tx":{"en":"--- SILENCE TRAINING BLOCK A ---","es":"--- BLOQUE DE SILENCIO A ---"},
"d":60,
"inf":{
"en":"1 minute silence improves attention stability and impulse control (prefrontal activation)",
"es":"1 minuto de silencio mejora atención y control de impulsos (activación prefrontal)"
}
},

{"id":26,"cat":"mind","b":[
{"t":"v","tx":{"en":"Today: MIND","es":"Hoy: MENTE"}},
{"t":"h","tx":{"en":"Chaotic thoughts","es":"Pensamientos caóticos"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":4},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":4,
"inf":{"en":"Regulates amygdala response","es":"Regula la amígdala reduciendo reactividad emocional"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["React","Organize","Escape","Ignore"],
"c":1,
"ex":[
"React = increases chaos",
"Organize = mental clarity",
"Escape = no solution",
"Ignore = worsens mental noise"
]},

{"t":"r","tx":"+Clarity","p":20},
{"t":"c","tx":{"en":"Order = control","es":"Orden = control"}}
]},

{"id":27,"cat":"calm","b":[
{"t":"v","tx":{"en":"Today: CALM","es":"Hoy: CALMA"}},
{"t":"h","tx":{"en":"Conflict appears","es":"Aparece conflicto"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Fight","Calm","Run","Scream"],
"c":1,
"ex":[
"Fight = escalates problem",
"Calm = superior emotional regulation",
"Run = avoids solution",
"Scream = less influence"
]},

{"t":"r","tx":"+Calm","p":20},
{"t":"c","tx":{"en":"Calm always wins","es":"La calma siempre gana"}}
]},

{"t":"br",
"tx":{"en":"--- SILENCE TRAINING BLOCK B ---","es":"--- BLOQUE DE SILENCIO B ---"},
"d":120,
"inf":{
"en":"2 minutes silence strengthens neuroplasticity and emotional regulation pathways",
"es":"2 minutos de silencio fortalecen neuroplasticidad y rutas de regulación emocional cerebral"
}
},

{"id":28,"cat":"final","b":[
{"t":"v","tx":{"en":"Today: TOTAL CONNECTION","es":"Hoy: CONEXIÓN TOTAL"}},
{"t":"h","tx":{"en":"Everything is connected","es":"Todo está conectado"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Ignore","Understand","Escape","React"],
"c":1,
"ex":[
"Ignore = no awareness",
"Understand = full vision",
"Escape = avoid reality",
"React = no analysis"
]},

{"t":"r","tx":"+Vision","p":20},

{"t":"v","tx":{"en":"FINAL CHALLENGE: SILENCE & VISION","es":"RETO FINAL: SILENCIO Y VISIÓN"}},

{"t":"br","tx":{"en":"Inhale deep","es":"Inhala profundo"},"d":6,
"inf":{"en":"Activates parasympathetic nervous system","es":"Activa sistema parasimpático"}},
{"t":"br","tx":{"en":"Hold","es":"Retén"},"d":3,
"inf":{"en":"Trains impulse control","es":"Entrena control de impulsos"}},
{"t":"br","tx":{"en":"Exhale slow","es":"Exhala lento"},"d":6,
"inf":{"en":"Reduces heart rate","es":"Reduce ritmo cardíaco"}},

{"t":"sil","d":120,
"tx":{"en":"Silent observation","es":"Observación silenciosa"},
"inf":{"en":"Metacognition training","es":"Entrenamiento de metacognición"}},

{"t":"c","tx":{"en":"See everything = master everything","es":"Ver todo = dominar todo"}}
]}

]
}
