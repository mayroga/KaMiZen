{
"sys":"KAMIZEN KIDS","ch":1,"rng":"1-7",

"ui":{"fw":["FOCUS","CALM","BREATH","ACTION","STOP","THINK","CONTROL"]},

"rules":["Obs>React","Act=Real","Thought>Emotion","Silence=Power","Focus>Noise","Breath=Ctrl"],

"ses":[

{"id":1,"cat":"aware","b":[
{"t":"v","tx":"Sistema activo. Hoy: OBSERVAR antes de actuar."},
{"t":"vis","tx":"Ruido. Tú en calma mirando todo."},
{"t":"br","tx":"Inhala","d":4},{"t":"br","tx":"Retén","d":2},{"t":"br","tx":"Exhala","d":4},
{"t":"h","tx":"Pasillo ruidoso. Algo importante escondido."},
{"t":"d","q":"¿Qué haces?","op":["Ignorar","Observar","Correr","Preguntar"],"c":1,
"ex":["Ignorar=cerebro pierde info clave.","Observar=tu cerebro detecta patrones (corteza prefrontal activa control).","Correr=evitas aprender.","Preguntar=dependes antes de pensar."]},
{"t":"r","tx":"+Conciencia","p":20},
{"t":"c","tx":"Observar primero = ventaja en vida."}
]},

{"id":2,"cat":"emotion","b":[
{"t":"v","tx":"Hoy: CONTROL emocional."},
{"t":"h","tx":"Algo activa emoción fuerte."},
{"t":"br","tx":"Inhala","d":5},{"t":"br","tx":"Retén","d":3},{"t":"br","tx":"Exhala","d":5},
{"t":"d","q":"¿Qué haces?","op":["Reaccionar","Respirar","Gritar","Ignorar"],"c":1,
"ex":["Reaccionar=amígdala domina, pierdes control.","Respirar=activa sistema parasimpático (calma real).","Gritar=liberas pero pierdes poder.","Ignorar=emoción sigue sin entenderse."]},
{"t":"r","tx":"+Control","p":20},
{"t":"c","tx":"Pausa=control real."}
]},

{"id":3,"cat":"choice","b":[
{"t":"v","tx":"Hoy: DECISIONES."},
{"t":"h","tx":"Fácil ahora o mejor después."},
{"t":"d","q":"¿Qué eliges?","op":["Fácil","Inteligente","Nada","Retrasar"],"c":1,
"ex":["Fácil=dopamina rápida, problemas luego.","Inteligente=corteza prefrontal construye futuro.","Nada=decisión pasiva, pierdes oportunidades.","Retrasar=aumenta estrés y presión."]},
{"t":"r","tx":"+Decisión","p":20},
{"t":"c","tx":"Pequeñas decisiones crean tu vida."}
]},

{"id":4,"cat":"pressure","b":[
{"t":"v","tx":"Hoy: PRESIÓN."},
{"t":"h","tx":"Grupo te presiona."},
{"t":"d","q":"¿Qué haces?","op":["Seguir","Calma","Escapar","Discutir"],"c":1,
"ex":["Seguir=pierdes identidad.","Calma=controlas sistema nervioso y decides mejor.","Escapar=no entrenas fuerza.","Discutir=sube emoción, baja lógica."]},
{"t":"r","tx":"+Fuerza","p":20},
{"t":"c","tx":"Bajo presión se revela quién eres."}
]},

{"id":5,"cat":"focus","b":[
{"t":"v","tx":"Hoy: ENFOQUE."},
{"t":"h","tx":"Muchas distracciones."},
{"t":"d","q":"¿Qué haces?","op":["Multitarea","1 tarea","Parar","Cambiar"],"c":1,
"ex":["Multitarea=divide atención (menos rendimiento).","1 tarea=flujo profundo (máximo rendimiento).","Parar=cero progreso.","Cambiar=rompe concentración."]},
{"t":"r","tx":"+Focus","p":20},
{"t":"c","tx":"El enfoque gana dinero, tiempo y resultados."}
]},

{"id":6,"cat":"social","b":[
{"t":"v","tx":"Hoy: PERSONAS."},
{"t":"h","tx":"Alguien actúa raro."},
{"t":"d","q":"¿Qué haces?","op":["Ignorar","Observar","Confrontar","Irse"],"c":1,
"ex":["Ignorar=pierdes señales sociales.","Observar=lees patrones reales (lenguaje no verbal).","Confrontar=riesgo sin info.","Irse=evitas aprender."]},
{"t":"r","tx":"+Lectura","p":20},
{"t":"c","tx":"Las acciones dicen la verdad."}
]},

{"id":7,"cat":"calm","b":[
{"t":"v","tx":"Hoy: DOMINIO TOTAL."},
{"t":"h","tx":"Te provocan fuerte."},
{"t":"d","q":"¿Qué haces?","op":["Explotar","Calma","Correr","Gritar"],"c":1,
"ex":["Explotar=entregas control.","Calma=tu cerebro ejecutivo domina.","Correr=evitas crecer.","Gritar=ruido sin poder."]},
{"t":"r","tx":"+Dominio","p":20},

{"t":"v","tx":"RETO FINAL: 2 MIN SILENCIO. Esto entrena control real del cerebro."},

{"t":"br","tx":"Inhala profundo","d":6,"inf":"Activa nervio vago → baja estrés"},
{"t":"br","tx":"Retén","d":3,"inf":"Aumenta tolerancia al impulso"},
{"t":"br","tx":"Exhala lento","d":6,"inf":"Reduce ritmo cardíaco"},

{"t":"br","tx":"Inhala corto","d":3,"inf":"Activa enfoque mental"},
{"t":"br","tx":"Exhala largo","d":6,"inf":"Profundiza calma y control emocional"},

{"t":"sil","d":120,"tx":"Silencio total. Observa pensamientos sin reaccionar.","inf":"Entrena metacognición: ver pensamientos sin ser ellos"},

{"t":"v","tx":"Si hiciste esto, tienes ventaja real sobre la mayoría."},

{"t":"c","tx":"Calma = poder en escuela, calle, dinero y vida."}
]}

]}
