{
"sys":"KAMIZEN KIDS",
"ch":1,
"rng":"1-7",

"ui":{"fw":["FOCUS","CALM","BREATH","ACTION","STOP","THINK","CONTROL"]},

"rules":["Obs>React","Act=Real","Thought>Emotion","Silence=Power","Focus>Noise","Breath=Ctrl"],

"ses":[

{"id":1,"cat":"aware","b":[
{"t":"v","tx":{"en":"System active: OBSERVE before acting","es":"Sistema activo: OBSERVA antes de actuar"}},
{"t":"vis","tx":{"en":"Noise. You are calm observing everything","es":"Ruido. Estás en calma observando todo"}},
{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":4},
{"t":"br","tx":{"en":"Hold","es":"Retén"},"d":2},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":4},

{"t":"h","tx":{"en":"A noisy hallway. Something important is hidden.","es":"Un pasillo ruidoso. Algo importante está oculto."}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Ignore","Observe","Run","Ask"],
"c":1,
"ex":[
"Ignore=brain misses key data",
"Observe=prefrontal cortex activates pattern detection",
"Run=avoid learning",
"Ask=depend before thinking"
]},

{"t":"r","tx":"+Awareness","p":20},
{"t":"c","tx":{"en":"Observe first = life advantage","es":"Observar primero = ventaja en la vida"}}
]},


{"id":2,"cat":"emotion","b":[
{"t":"v","tx":{"en":"Today: EMOTIONAL CONTROL","es":"Hoy: CONTROL EMOCIONAL"}},
{"t":"h","tx":{"en":"Something triggers strong emotion","es":"Algo activa una emoción fuerte"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":5},
{"t":"br","tx":{"en":"Hold","es":"Retén"},"d":3},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":5},

{"t":"h","tx":{"en":"2 MIN SILENCE TRAINING (BRAIN CALM RESET)","es":"ENTRENAMIENTO 2 MIN SILENCIO (RESET DE CALMA CEREBRAL)"}},

{"t":"sil","d":120,
"tx":{"en":"Silent observation. No reaction allowed.","es":"Observación en silencio. Sin reacción permitida."},
"inf":{
"en":"Activates parasympathetic system → lowers cortisol → improves prefrontal control",
"es":"Activa sistema parasimpático → reduce cortisol → mejora control prefrontal"
}},

{"t":"c","tx":{"en":"Pause = real control","es":"Pausa = control real"}}
]},


{"id":3,"cat":"choice","b":[
{"t":"v","tx":{"en":"Today: DECISIONS","es":"Hoy: DECISIONES"}},
{"t":"h","tx":{"en":"Easy now or better later","es":"Fácil ahora o mejor después"}},

{"t":"d","q":{"en":"What do you choose?","es":"¿Qué eliges?"},
"op":["Easy","Smart","Nothing","Delay"],
"c":1,
"ex":[
"Easy=short dopamine, future problems",
"Smart=builds future neural structure",
"Nothing=passive loss",
"Delay=increases stress load"
]},

{"t":"r","tx":"+Decision","p":20}
]},


{"id":4,"cat":"pressure","b":[
{"t":"v","tx":{"en":"Today: SOCIAL PRESSURE","es":"Hoy: PRESIÓN SOCIAL"}},
{"t":"h","tx":{"en":"Group is pushing you","es":"El grupo te está presionando"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":4},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":4},

{"t":"h","tx":{"en":"1 MIN SILENCE TEST (FAST CONTROL RESET)","es":"PRUEBA 1 MIN SILENCIO (RESET RÁPIDO DE CONTROL)"}},

{"t":"sil","d":60,
"tx":{"en":"Stay silent. Observe pressure without reacting","es":"Permanece en silencio. Observa la presión sin reaccionar"},
"inf":{
"en":"Trains impulse inhibition and amygdala control",
"es":"Entrena inhibición de impulsos y control de la amígdala"
}},

{"t":"r","tx":"+Strength","p":20}
]},


{"id":5,"cat":"focus","b":[
{"t":"v","tx":{"en":"Today: FOCUS","es":"Hoy: ENFOQUE"}},
{"t":"h","tx":{"en":"Many distractions appear","es":"Aparecen muchas distracciones"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Multitask","One task","Stop","Switch"],
"c":1,
"ex":[
"Multitask=attention split",
"One task=deep focus state",
"Stop=no progress",
"Switch=breaks neural flow"
]},

{"t":"r","tx":"+Focus","p":20}
]},


{"id":6,"cat":"social","b":[
{"t":"v","tx":{"en":"Today: PEOPLE ANALYSIS","es":"Hoy: ANÁLISIS DE PERSONAS"}},
{"t":"h","tx":{"en":"Someone behaves strangely","es":"Alguien se comporta extraño"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Ignore","Observe","Confront","Leave"],
"c":1},

{"t":"r","tx":"+Reading","p":20}
]},


{"id":7,"cat":"calm","b":[
{"t":"v","tx":{"en":"FINAL DOMINANCE TEST","es":"PRUEBA FINAL DE DOMINIO"}},
{"t":"h","tx":{"en":"Someone provokes you strongly","es":"Alguien te provoca fuertemente"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Explode","Calm","Run","Shout"],
"c":1},

{"t":"r","tx":"+Control","p":20},

{"t":"v","tx":{"en":"FINAL SILENCE TRAINING","es":"ENTRENAMIENTO FINAL DE SILENCIO"}},

{"t":"br","tx":{"en":"Deep inhale","es":"Inhala profundo"},"d":6},
{"t":"br","tx":{"en":"Hold","es":"Retén"},"d":3},
{"t":"br","tx":{"en":"Slow exhale","es":"Exhala lento"},"d":6},

{"t":"sil","d":120,
"tx":{"en":"Observe thoughts without reacting","es":"Observa pensamientos sin reaccionar"},
"inf":{
"en":"Builds metacognition (thinking about thinking)",
"es":"Desarrolla metacognición (pensar sobre el pensamiento)"
}},

{"t":"c","tx":{"en":"Calm = real power","es":"Calma = poder real"}}
]}

]}
