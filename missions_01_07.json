{"t":"v","tx":{"en":"Today: AWARENESS IN SCHOOL"}},
{"t":"h","tx":{"en":"Your mind interprets reality — pay attention"}},

{"story":{"en":"A lamp in a dark room reveals what was always there. Awareness changes your decisions."}},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
},

{"t":"d","q":{"en":"You feel something is off. What do you do?"},
"op":["Ignore","Observe carefully","Run randomly","Freeze"],
"c":1,
"ex":[
"Ignore = miss reality",
"Observe = gain control",
"Random reaction = confusion",
"Freeze = no decision"
]},

{"t":"r","tx":"+Awareness","p":20},
{"t":"c","tx":{"en":"Attention is your most valuable resource"}},

{"t":"sil","d":30,
"tx":{"en":"30 seconds of focused awareness"},
"inf":{"en":"Improves perception and reduces automatic behavior"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
}
]
},

