    {
      "id": 1,
      "level": 1,
      "category": "Nacimiento y Conciencia Inicial",
      "blocks": [
        {
          "type": "voice",
          "text": {
            "en": "You enter life without control. Everything begins reacting.",
            "es": "Entras en la vida sin control. Todo comienza reaccionando."
          }
        },
        {
          "type": "strategy",
          "text": {
            "en": "Every stimulus creates a response. Awareness is your first power.",
            "es": "Cada estímulo crea una respuesta. La conciencia es tu primer poder."
          }
        },
        {
          "type": "breathing",
          "duration": 5,
          "text": {
            "en": "Breath connects you with existence.",
            "es": "La respiración te conecta con la existencia."
          }
        }
      ]
    },

    {
      "id": 2,
      "level": 1,
      "category": "Relaciones Iniciales",
      "blocks": [
        {
          "type": "voice",
          "text": {
            "en": "Family, friends, strangers. All influence your identity.",
            "es": "Familia, amigos, desconocidos. Todos influyen en tu identidad."
          }
        },
        {
          "type": "quiz",
          "question": {
            "en": "Someone rejects you. What defines you?",
            "es": "Alguien te rechaza. ¿Qué te define?"
          },
          "options": {
            "en": ["Their opinion", "Your reaction", "The moment"],
            "es": ["Su opinión", "Tu reacción", "El momento"]
          },
          "correct": 1
        },
        {
          "type": "story",
          "text": {
            "en": "Rejection is not the end. It is a mirror.",
            "es": "El rechazo no es el final. Es un espejo."
          }
        }
      ]
    },

    {
      "id": 3,
      "level": 2,
      "category": "Presión Social y Conflictos",
      "blocks": [
        {
          "type": "voice",
          "text": {
            "en": "Conflict is inevitable. Reaction is optional.",
