{"type":"analysis","text":{"en":"Attention is power.","es":"La atención es poder."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Check phone","es":"Revisar teléfono"},"correct":false,"explanation":"Giving attention to distractions weakens your focus."},
{"code":"B","text":{"en":"Control time","es":"Controlar tiempo"},"correct":true,"explanation":"Controlling attention increases productivity and discipline."},
{"code":"C","text":{"en":"Ignore work","es":"Ignorar trabajo"},"correct":false,"explanation":"Ignoring responsibilities creates future stress."},
{"code":"D","text":{"en":"Quit task","es":"Abandonar tarea"},"correct":false,"explanation":"Quitting removes progress and builds weak habits."}
]}]},

{"id":10,"level":10,"theme":"PRESSURE","blocks":[
