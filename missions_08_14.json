{"code":"A","text":{"en":"Rush","es":"Apresurar"},"correct":false,"explanation":"Rushing leads to mistakes and poor decisions."},
{"code":"B","text":{"en":"Pause think","es":"Pausar pensar"},"correct":true,"explanation":"Pausing allows clarity and better decisions."},
{"code":"C","text":{"en":"Guess","es":"Adivinar"},"correct":false,"explanation":"Guessing removes logic and increases risk."},
{"code":"D","text":{"en":"Avoid","es":"Evitar"},"correct":false,"explanation":"Avoiding decisions creates bigger problems later."}
