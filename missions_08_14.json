{"code":"B","text":{"en":"Accept","es":"Aceptar"},"correct":true,"explanation":"Accepting responsibility builds strength and respect."},
{"code":"C","text":{"en":"Blame","es":"Culpar"},"correct":false,"explanation":"Blaming others removes your power to improve."},
{"code":"D","text":{"en":"Hide","es":"Ocultar"},"correct":false,"explanation":"Hiding mistakes increases consequences later."}
]}]},

{"id":12,"level":12,"theme":"CONTROL","blocks":[
