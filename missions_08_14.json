{"t":"v","tx":{"en":"Today: AWARENESS IN PUBLIC SPACES"}},
{"t":"h","tx":{"en":"Your attention determines your safety"}},

{"story":{"en":"Most people move on autopilot. Awareness gives you an advantage before problems appear."}},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
},

{"t":"d","q":{"en":"What increases your safety most?"},
"op":["Look at phone","Observe exits and people","Ignore surroundings","Walk distracted"],
"c":1,
"ex":[
"Phone = reduced awareness",
"Observation = control of environment",
"Ignoring = vulnerability",
"Distraction = delayed reaction"
]},

{"t":"r","tx":"+Awareness","p":20},
{"t":"c","tx":{"en":"Attention is your most valuable resource"}},

{"t":"sil","d":60,
"tx":{"en":"Observe without reacting"},
"inf":{"en":"Improves situational awareness and reduces automatic behavior"}
},

{"t":"breath_auto","d":30,
"tx":{"en":"Inhale and exhale slowly"},
"inf":{"en":"This exercise trains calm control and focus"}
}
]
},

