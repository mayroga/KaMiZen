{"id":8,"level":8,"theme":"TRUTH","blocks":[
{"type":"story","text":{"en":"Truth is risky.","es":"La verdad es riesgosa."}},
{"type":"analysis","text":{"en":"Truth builds character.","es":"La verdad construye carácter."}},
{"type":"decision","options":[
{"code":"A","text":{"en":"Lie","es":"Mentir"},"correct":false,"explanation":"Lying gives short-term escape but destroys long-term trust."},
{"code":"B","text":{"en":"Truth calm","es":"Verdad calmada"},"correct":true,"explanation":"Calm truth builds respect and strong identity."},
{"code":"C","text":{"en":"Hide","es":"Ocultar"},"correct":false,"explanation":"Hiding delays consequences but increases pressure."},
{"code":"D","text":{"en":"Delay","es":"Retrasar"},"correct":false,"explanation":"Delaying truth makes situations worse over time."}
]}]},

{"id":9,"level":9,"theme":"DISTRACTION","blocks":[
