          {"code":"PAUSE","text":{"en":"Pause and breathe","es":"Pausar y respirar"},"correct":true,"explanation":{"en":"Breathing restores control and prevents emotional reaction.","es":"Respirar restaura el control y evita reacciones emocionales."}},
