{"t":"d","q":{"en":"What is true control?"},
"op":["Explode","Ignore blindly","Breathe and regulate","Attack"],
"c":2,
"ex":[
"Explode = loss of self-control",
"Blind ignoring = no awareness processing",
"Breathe + regulate = executive control activation",
"Attack = escalation and consequence increase"
]},

{"t":"r","tx":"+Control","p":20},
{"t":"c","tx":{"en":"Emotional control = real power"}},

{"t":"sil","d":30,
"tx":{"en":"Silent emotional reset"},
