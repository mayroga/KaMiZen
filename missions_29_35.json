{
"sys":"KAMIZEN KIDS",
"ch":4,
"rng":"29-35",

"ui":{"fw":["DISCIPLINE","AWARENESS","CALM","FOCUS","TRUTH","CONTROL","ACTION","PAUSE"]},

"rules":["MasterSelf","Awareness=Freedom","Emotion=Data","Silence=Truth","Focus=Reality","Discipline>Impulse","Calm=Power","Action=Identity"],

"ses":[

{"id":29,"cat":"emotion","b":[
{"t":"v","tx":{"en":"Today: EMOTIONAL TRAP","es":"Hoy: TRAMPA EMOCIONAL"}},
{"t":"h","tx":{"en":"You are insulted in public","es":"Te insultan en público"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":5},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":5,
"inf":{"en":"Parasympathetic activation → reduces cortisol and emotional reactivity",
"es":"Activación parasimpática → reduce cortisol y reactividad emocional"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Explode","Ignore","Breathe","Attack"],
"c":2,
"ex":[
"Explode = lose control",
"Ignore without awareness = no learning",
"Breathe = regulates emotion (real control)",
"Attack = escalates conflict"
]},

{"t":"r","tx":"+Control","p":20},
{"t":"c","tx":{"en":"Emotional control = power","es":"Control emocional = poder"}}
]},

{"id":30,"cat":"focus","b":[
{"t":"v","tx":{"en":"Today: FOCUS","es":"Hoy: ENFOQUE"}},
{"t":"h","tx":{"en":"Distractions appear","es":"Aparecen distracciones"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Multitask","Stop","Focus","Phone"],
"c":2,
"ex":[
"Multitasking = low performance",
"Stopping = no progress",
"Focusing = improves attention network (prefrontal cortex)",
"Phone = breaks mental flow"
]},

{"t":"r","tx":"+Focus","p":20},
{"t":"c","tx":{"en":"Attention = energy","es":"Atención = energía"}}
]},

{"t":"br",
"tx":{"en":"--- SILENCE BLOCK A ---","es":"--- BLOQUE DE SILENCIO A ---"},
"d":60,
"inf":{
"en":"1 minute silence improves attention stability and impulse inhibition",
"es":"1 minuto de silencio mejora atención y control de impulsos"
}
},

{"id":31,"cat":"truth","b":[
{"t":"v","tx":{"en":"Today: TRUTH","es":"Hoy: VERDAD"}},
{"t":"h","tx":{"en":"Hidden mistake","es":"Error oculto"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Lie","Blame","Truth","Ignore"],
"c":2,
"ex":[
"Lying damages identity",
"Blaming avoids growth",
"Truth builds neural coherence and trust",
"Ignoring = no improvement"
]},

{"t":"r","tx":"+Integrity","p":20},
{"t":"c","tx":{"en":"Truth creates respect","es":"La verdad crea respeto"}}
]},

{"id":32,"cat":"social","b":[
{"t":"v","tx":{"en":"Today: SOCIAL PRESSURE","es":"Hoy: PRESIÓN SOCIAL"}},
{"t":"h","tx":{"en":"You are pressured wrongly","es":"Te presionan mal"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Follow","Laugh","Say no","Escape"],
"c":2,
"ex":[
"Following = identity loss",
"Laughing = normalizes error",
"Saying no = activates autonomy and leadership",
"Escaping = no trust building"
]},

{"t":"r","tx":"+Strength","p":20},
{"t":"c","tx":{"en":"Saying no = leadership","es":"Decir no = liderazgo"}}
]},

{"id":33,"cat":"mind","b":[
{"t":"v","tx":{"en":"Today: MENTAL CHAOS","es":"Hoy: CAOS MENTAL"}},
{"t":"h","tx":{"en":"Fast thoughts","es":"Pensamientos rápidos"}},

{"t":"br","tx":{"en":"Inhale","es":"Inhala"},"d":4},
{"t":"br","tx":{"en":"Exhale","es":"Exhala"},"d":4,
"inf":{"en":"Neural reset through breathing",
"es":"Reinicio neural mediante respiración"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Overthink","Breathe","Act","Ignore"],
"c":1,
"ex":[
"Overthinking = confusion",
"Breathe = reduces amygdala activity and restores order",
"Acting without clarity = errors",
"Ignoring = no understanding mind"
]},

{"t":"r","tx":"+Clarity","p":20},
{"t":"c","tx":{"en":"Calm = clarity","es":"Calma = claridad"}}
]},

{"t":"br",
"tx":{"en":"--- SILENCE BLOCK B ---","es":"--- BLOQUE DE SILENCIO B ---"},
"d":120,
"inf":{
"en":"2 minutes silence strengthens neuroplasticity and emotional regulation networks",
"es":"2 minutos de silencio fortalecen neuroplasticidad y redes de regulación emocional cerebral"
}
},

{"id":34,"cat":"inner","b":[
{"t":"v","tx":{"en":"Today: INNER CONTROL","es":"Hoy: CONTROL INTERNO"}},
{"t":"h","tx":{"en":"Strong emotion","es":"Emoción fuerte"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["React","Ignore","Observe","Avoid"],
"c":2,
"ex":[
"Reacting = no control",
"Ignoring = not solving",
"Observing = increases metacognition and emotional mastery",
"Avoiding = no growth"
]},

{"t":"r","tx":"+Mastery","p":20},
{"t":"c","tx":{"en":"Observe = control","es":"Observar = controlar"}}
]},

{"id":35,"cat":"final","b":[
{"t":"v","tx":{"en":"FINAL TEST: DISCIPLINE","es":"PRUEBA FINAL: DISCIPLINA"}},
{"t":"h","tx":{"en":"Total distraction","es":"Distracción total"}},

{"t":"d","q":{"en":"What do you do?","es":"¿Qué haces?"},
"op":["Quit","Distract","Focus","React"],
"c":2,
"ex":[
"Quitting = breaks discipline",
"Distracting = no mastery",
"Focusing = full prefrontal control",
"Reacting = no precision"
]},

{"t":"r","tx":"+Mastery","p":20},

{"t":"v","tx":{"en":"FINAL CHALLENGE: TOTAL SILENCE","es":"RETO FINAL: SILENCIO TOTAL"}},

{"t":"br","tx":{"en":"Inhale deep","es":"Inhala profundo"},"d":6,
"inf":{"en":"Activates parasympathetic system","es":"Activa sistema parasimpático"}},

{"t":"br","tx":{"en":"Hold","es":"Retén"},"d":3,
"inf":{"en":"Impulse control training","es":"Entrenamiento de control de impulsos"}},

{"t":"br","tx":{"en":"Exhale slow","es":"Exhala lento"},"d":6,
"inf":{"en":"Heart rate reduction","es":"Reducción del ritmo cardíaco"}},

{"t":"sil","d":120,
"tx":{"en":"Do not move. Just observe.","es":"Sin moverte. Solo observa"},
"inf":{"en":"High-level metacognitive control","es":"Control metacognitivo avanzado"}},

{"t":"v","tx":{"en":"You have completed the system","es":"Has completado el sistema"}},

{"t":"c","tx":{"en":"Discipline + control = real power in life","es":"Disciplina + control = poder real en la vida"}}
]}

]
}
